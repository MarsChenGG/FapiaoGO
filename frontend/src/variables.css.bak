/* ================================================================
   variables.css — CSS Custom Properties
   ================================================================ */

:root {
  transition: background-color 0.3s ease, color 0.3s ease;

  --bg: oklch(0.97 0.003 260);
  --white: #ffffff;
  --sidebar-bg: color-mix(in srgb, #ffffff 99%, #3b6cf5 1%);
  --surface: oklch(0.99 0.002 260);
  --paper-bg: #ffffff;
  --surface-hover: #eceef2;
  --border: oklch(0.88 0.005 260);
  --border-light: #eef0f4;
  --border-hover: #c8cdd8;
  --hover-bg: #eceef2;

  --canvas-float-bg: rgba(255, 255, 255, 0.95);
  --canvas-float-border: rgba(0, 0, 0, 0.06);

  --accent: #3b6cf5;
  --brand: #476df9;
  --accent-hover: #2d5be0;
  --accent-dark: #2d5be0;
  --accent-soft: rgba(59, 108, 245, 0.06);
  --accent-medium: rgba(59, 108, 245, 0.10);

  --text: oklch(0.20 0.01 260);
  --text-2: oklch(0.40 0.01 260);
  --text-3: oklch(0.55 0.01 260);
  --text-4: oklch(0.70 0.005 260);

  --green: #22c55e;
  --green-soft: rgba(34, 197, 94, 0.08);
  --orange: #f59e0b;
  --orange-soft: rgba(245, 158, 11, 0.08);
  --red: #e53e3e;
  --red-soft: rgba(229, 62, 62, 0.06);
  --purple: #7c3aed;
  --purple-soft: rgba(124, 58, 237, 0.08);

  --success: #22c55e;
  --success-bg: rgba(34, 197, 94, 0.08);
  --info: #3b6cf5;
  --info-bg: rgba(59, 108, 245, 0.06);
  --warning: #f59e0b;
  --warning-bg: rgba(245, 158, 11, 0.08);
  --danger: #e53e3e;
  --danger-bg: rgba(229, 62, 62, 0.06);

  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.03);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.05);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.08);
  --shadow-xl: 0 16px 48px rgba(0, 0, 0, 0.10);
  --shadow-2xl: 0 25px 50px -12px rgba(0, 0, 0, 0.18);

  --r-sm: 6px;
  --r-md: 8px;
  --r-lg: 10px;
  --r-xl: 12px;
  --r-2xl: 16px;

  --ease: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --t-fast: 0.15s;
  --t-normal: 0.25s;
  --t-slow: 0.4s;
}

/* ═════════════════════════════════════
   DARK MODE — Deep Slate · 高清可读
   设计参考：Linear / GitHub / Stripe 暗色模式
   核心策略：深色 UI 作画框沉入背景，白色发票预览自然突出
   ═════════════════════════════════════ */
[data-theme="dark"] {
  /* ── 背景层次（深石板色，四级递进） ── */
  --bg: #0f1117;                  /* 画布底 — 最深，承载白色发票 */
  --white: #191c24;               /* 容器 — 顶栏/底栏/弹窗/下拉 */
  --sidebar-bg: #14171f;          /* 侧栏 — 介于 bg 与 white 之间 */
  --surface: #1e2130;             /* 卡片/区块 — 浮于容器之上 */
  --surface-hover: #262a38;       /* 悬停 — 微提亮 */
  --paper-bg: #ffffff;            /* 发票纸张 — 纯白，与深色 UI 形成自然对比 */
  --border: #2d3040;              /* 边框 — 清晰可见 */
  --border-light: #222536;        /* 细边框 — 分隔但不过分强调 */
  --border-hover: #3d4058;        /* 交互边框 — 聚焦反馈 */
  --hover-bg: #262a38;            /* 通用悬停底 */

  --canvas-float-bg: rgba(20, 23, 31, 0.96);
  --canvas-float-border: rgba(255, 255, 255, 0.07);

  /* ── 强调色 · 冷静蓝（区别于亮色模式的 warm blue） ── */
  --accent: #6c8aff;
  --brand: #6c8aff;
  --accent-hover: #8aa3ff;
  --accent-dark: #5670e0;
  --accent-soft: rgba(108, 138, 255, 0.12);
  --accent-medium: rgba(108, 138, 255, 0.18);

  /* ── 文字层级（WCAG AA 可读性优先） ── */
  --text: #e3e5ed;                /* 正文 — 约 15:1 对比度    */
  --text-2: #acb0c4;              /* 次要 — 约 8:1 对比度    */
  --text-3: #6f7389;              /* 辅助 — 标签/提示/占位   */
  --text-4: #484b5e;              /* 禁用 — 弱化但可辨       */

  /* ── 功能色 · 暗色适配（提饱和度以保持辨识度） ── */
  --green: #4ade80;
  --green-soft: rgba(74, 222, 128, 0.10);
  --orange: #fb923c;
  --orange-soft: rgba(251, 146, 60, 0.10);
  --red: #f87171;
  --red-soft: rgba(248, 113, 113, 0.10);
  --purple: #a78bfa;
  --purple-soft: rgba(167, 139, 250, 0.10);

  --success: #4ade80;
  --success-bg: rgba(74, 222, 128, 0.10);
  --info: #6c8aff;
  --info-bg: rgba(108, 138, 255, 0.10);
  --warning: #fb923c;
  --warning-bg: rgba(251, 146, 60, 0.10);
  --danger: #f87171;
  --danger-bg: rgba(248, 113, 113, 0.10);

  /* ── 阴影 · 层次分明（暗色下阴影需更深、范围更广） ── */
  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.35), 0 1px 2px rgba(0, 0, 0, 0.25);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
  --shadow-xl: 0 16px 48px rgba(0, 0, 0, 0.55);
  --shadow-2xl: 0 25px 50px -12px rgba(0, 0, 0, 0.65);
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}
