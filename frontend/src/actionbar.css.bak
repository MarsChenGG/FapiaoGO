/* ================================================================
   actionbar.css — Action Bars, Buttons
   ================================================================ */

/* ======================== Action Bar ======================== */
.actionbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 26px;
  height: 62px;
  background: var(--white);
  border-top: 1px solid var(--border-light);
  flex-shrink: 0;
  z-index: 10;
}

/* ======================== Modern Action Bar ======================== */
.actionbar-modern {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  height: 64px;
  background: var(--white);
  border-top: 1px solid var(--border-light);
  flex-shrink: 0;
  z-index: 10;
  gap: 12px;
}

/* ---- 左侧金额卡片 ---- */
.abm-left {
  display: flex;
  align-items: center;
}

.abm-amount-card {
  display: flex;
  align-items: baseline;
  gap: 12px;
  padding: 6px 16px;
  border-radius: var(--r-lg);
  background: var(--surface);
  border: 1px solid var(--border-light);
}

.abm-amount-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-3);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.abm-amount-value {
  display: flex;
  align-items: baseline;
  line-height: 1;
}

.abm-amount-int {
  font-family: 'MiSans', 'NotoSansSymbols', 'NotoSansSymbols2', 'PingFang SC', 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 22px;
  font-weight: 600;
  color: var(--text);
  letter-spacing: -0.02em;
}

.abm-amount-decimal {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-3);
}

.abm-amount-cn {
  font-size: 11px;
  color: var(--text-3);
  max-width: 280px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1;
}

/* ---- 右侧按钮组 ---- */
.abm-right {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-left: auto;
  flex-shrink: 0;
}

/* ---- 按钮容器 ---- */
.abm-btn-wrapper {
  position: relative;
}

/* ---- 按钮基类 ---- */
.abm-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 8px 14px;
  border: none;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  white-space: nowrap;
  line-height: 1;
  outline: none;
  height: 38px;
  box-sizing: border-box;
}

.abm-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  pointer-events: none;
}

/* ---- 按钮图标区域 ---- */
.abm-btn-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 22px;
  height: 22px;
  flex-shrink: 0;
}

.abm-btn-icon img {
  width: 16px;
  height: 16px;
}

.abm-btn-icon svg {
  width: 16px;
  height: 16px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* ---- 按钮文字区域 ---- */
.abm-btn-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  line-height: 1;
  gap: 2px;
}

.abm-btn-text {
  font-size: 13px;
  font-weight: 500;
  color: inherit;
}

.abm-btn-progress {
  font-size: 10px;
  font-weight: 600;
  opacity: 0.7;
  font-family: 'JetBrains Mono', 'SF Mono', 'Consolas', monospace;
}

/* ---- 进度条 ---- */
.abm-progress-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 0 0 10px 10px;
  overflow: hidden;
}

.abm-progress-fill {
  height: 100%;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 0 0 10px 10px;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ---- 旋转动画 ---- */
@keyframes abmSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.abm-spinner {
  animation: abmSpin 1s linear infinite;
  transform-origin: center;
}

/* ---- 重命名按钮 — 中性辅助操作 ---- */
.abm-btn-rename {
  background: var(--surface);
  color: var(--text-2);
  border: 1px solid transparent;
}

.abm-btn-rename:hover:not(:disabled) {
  background: #e8ecf4;
  color: var(--text);
  transform: translateY(-1px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.abm-btn-rename:active:not(:disabled) {
  transform: translateY(0) scale(0.97);
  box-shadow: none;
}

.abm-btn-rename.executing {
  background: #eef2ff;
  color: var(--accent);
  border-color: rgba(59, 108, 245, 0.2);
  cursor: not-allowed;
}

.abm-btn-rename .abm-progress-bar {
  background: rgba(59, 108, 245, 0.1);
}

.abm-btn-rename .abm-progress-fill {
  background: var(--accent);
}

/* ---- 打包导出按钮 — 重要操作 ---- */
.abm-btn-pack {
  background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
  color: #059669;
  border: 1px solid rgba(5, 150, 105, 0.2);
}

.abm-btn-pack:hover:not(:disabled) {
  background: linear-gradient(135deg, #d1fae5 0%, #ccfbf1 100%);
  color: #047857;
  transform: translateY(-1px);
  box-shadow: 0 2px 12px rgba(5, 150, 105, 0.15);
  border-color: rgba(5, 150, 105, 0.35);
}

.abm-btn-pack:active:not(:disabled) {
  transform: translateY(0) scale(0.97);
  box-shadow: none;
}

.abm-btn-pack.executing {
  background: #ecfdf5;
  color: #059669;
  border-color: rgba(5, 150, 105, 0.25);
  cursor: not-allowed;
}

.abm-btn-pack .abm-progress-bar {
  background: rgba(5, 150, 105, 0.1);
}

.abm-btn-pack .abm-progress-fill {
  background: #059669;
}

/* ---- 打印/导出按钮 — 核心主操作 ---- */
.abm-btn-print {
  background: var(--accent);
  color: #fff;
  box-shadow: 0 2px 12px rgba(59, 108, 245, 0.3);
  padding-right: 16px;
}

.abm-btn-print:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 4px 20px rgba(59, 108, 245, 0.4);
  background: var(--accent-hover);
}

.abm-btn-print:active:not(:disabled) {
  transform: translateY(0) scale(0.97);
  box-shadow: 0 1px 6px rgba(59, 108, 245, 0.2);
}

.abm-btn-print.executing {
  background: var(--accent);
  opacity: 0.75;
  cursor: not-allowed;
}

/* ---- 徽章 ---- */
.abm-badge {
  position: absolute;
  top: -5px;
  right: -5px;
  min-width: 20px;
  height: 20px;
  padding: 0 5px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ef4444;
  color: #fff;
  border-radius: 10px;
  font-size: 10px;
  font-weight: 700;
  font-family: 'JetBrains Mono', 'SF Mono', 'Consolas', monospace;
  border: 2px solid var(--white);
  line-height: 1;
}

.ab-left {
  display: flex;
  align-items: baseline;
  gap: 28px;
}

.ab-right {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-left: auto;
}

.ab-total {
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.ab-total-label {
  font-size: 12.5px;
  color: var(--text-3);
}

.ab-total-amount {
  font-family: 'MiSans', 'NotoSansSymbols', 'NotoSansSymbols2', 'PingFang SC', 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 24px;
  font-weight: 500;
  color: var(--text);
  letter-spacing: -0.03em;
  line-height: 1;
}

.ab-total-unit {
  font-size: 14px;
  font-weight: 400;
  color: var(--text-3);
  margin-left: 0;
}

.ab-cn {
  font-size: 12px;
  color: var(--text-3);
  max-width: 340px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

/* ======================== Buttons ======================== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 8px 16px;
  border: none;
  border-radius: 9px;
  font-size: 13px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  transition: all var(--t-fast) var(--ease);
  white-space: nowrap;
  position: relative;
  line-height: 1;
}

.btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.btn svg {
  width: 15px;
  height: 15px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  flex-shrink: 0;
}

.btn-subtle {
  background: transparent;
  color: var(--text-2);
}
.btn-subtle:hover:not(:disabled) {
  background: var(--surface);
  color: var(--text);
}

.btn-outline {
  background: var(--white);
  color: var(--text-2);
  border: 1px solid var(--border);
}
.btn-outline:hover:not(:disabled) {
  background: var(--surface);
  border-color: var(--text-3);
  color: var(--text);
}

.btn-brand {
  background: var(--accent);
  color: #fff;
  box-shadow: 0 2px 8px rgba(59, 108, 245, 0.25);
  padding-right: 14px;
}
.btn-brand:hover:not(:disabled) {
  background: var(--accent-hover);
  box-shadow: 0 4px 14px rgba(59, 108, 245, 0.35);
  transform: translateY(-1px);
}
.btn-brand:active:not(:disabled) {
  transform: translateY(0);
}

.btn-brand .btn-arrow {
  width: 1px;
  height: 16px;
  background: rgba(255, 255, 255, 0.3);
  margin-left: 4px;
}

.btn-badge {
  position: absolute;
  top: -6px;
  right: -6px;
  min-width: 20px;
  height: 20px;
  padding: 0 5px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent);
  color: #fff;
  border-radius: 10px;
  font-size: 10px;
  font-weight: 700;
  font-family: 'JetBrains Mono', 'SF Mono', 'Consolas', monospace;
  border: 2px solid var(--white);
  line-height: 1;
}

/* -- ActionBar 移除失败文件按钮 -- */
.ab-total-remove-failed {
  display: flex;
  align-items: center;
}
.ab-total-btn-remove-failed {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border: none;
  border-radius: var(--r-lg);
  background: var(--danger-bg);
  color: var(--danger);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--t-fast) var(--ease);
  font-family: inherit;
}
.ab-total-btn-remove-failed:hover {
  background: rgba(229, 62, 62, 0.15);
  transform: translateY(-1px);
}
.ab-total-btn-remove-failed svg {
  width: 16px;
  height: 16px;
  stroke: var(--danger);
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}
.ab-total-label-remove-failed {
  font-size: 13px;
  color: var(--danger);
}

/* -- 分裂按钮样式 -- */
.abm-btn-split {
  position: relative;
  display: flex;
  align-items: stretch;
}

.abm-btn-pack-main {
  border-radius: var(--r-lg) 0 0 var(--r-lg);
  border-right: none;
  background: var(--surface);
  color: var(--text-2);
  border: 1px solid transparent;
}

.abm-btn-pack-main:hover:not(:disabled) {
  background: #e8ecf4;
  color: var(--text);
  border-color: transparent;
  transform: translateY(-1px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.abm-btn-pack-main:active:not(:disabled) {
  transform: translateY(0);
  box-shadow: none;
}

.abm-btn-pack-split {
  width: 32px;
  min-width: 32px;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 0 var(--r-lg) var(--r-lg) 0;
  border: 1px solid transparent;
  border-left: none;
  background: var(--surface);
  color: var(--text-2);
}

.abm-btn-pack-split::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  height: 60%;
  width: 1px;
  background: linear-gradient(to bottom, transparent, var(--border), transparent);
}

.abm-btn-pack-split:hover:not(:disabled) {
  background: #e8ecf4;
  color: var(--text);
  transform: translateY(-1px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.abm-btn-pack-split:active:not(:disabled) {
  transform: translateY(0);
  box-shadow: none;
}

.abm-btn-pack-main.executing,
.abm-btn-pack-split.executing {
  background: #eef2ff;
  color: var(--accent);
  border-color: rgba(59, 108, 245, 0.2);
  cursor: not-allowed;
}

.abm-btn-pack-split svg {
  width: 14px;
  height: 14px;
}

/* -- 下拉菜单 -- */
.abm-dropdown {
  position: absolute;
  bottom: calc(100% + 8px);
  right: 0;
  min-width: 160px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  padding: 6px;
  z-index: 100;
  animation: dropdownFadeIn 0.15s ease;
}

@keyframes dropdownFadeIn {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 删除底部中间的箭头 */

.abm-dropdown-item {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 10px 12px;
  border: none;
  border-radius: 6px;
  background: transparent;
  color: var(--text);
  font-size: 13px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.15s ease;
  text-align: left;
  position: relative;
}

.abm-dropdown-item::after {
  content: '';
  position: absolute;
  bottom: -12px;
  right: 8px;
  width: 10px;
  height: 10px;
  background: var(--white);
  border-right: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  transform: rotate(45deg);
}

.abm-dropdown-item:hover:not(:disabled) {
  background: var(--surface);
  color: var(--accent);
}

.abm-dropdown-item:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.abm-dropdown-item svg {
  width: 16px;
  height: 16px;
  stroke: currentColor;
  stroke-width: 2;
  flex-shrink: 0;
}

/* ================================================================
   DARK MODE — actionbar
   ================================================================ */
[data-theme="dark"] .abm-btn-print {
  background: var(--accent);
  box-shadow: 0 2px 12px rgba(91, 141, 239, 0.3);
}

[data-theme="dark"] .abm-btn-print:hover:not(:disabled) {
  box-shadow: 0 4px 20px rgba(91, 141, 239, 0.4);
  background: var(--accent-hover);
}

[data-theme="dark"] .abm-btn-print:active:not(:disabled) {
  box-shadow: 0 1px 6px rgba(91, 141, 239, 0.2);
}

[data-theme="dark"] .abm-btn-print.executing {
  background: var(--accent);
  opacity: 0.75;
}

[data-theme="dark"] .abm-btn-rename {
  background: var(--surface);
  color: var(--text-2);
}

[data-theme="dark"] .abm-btn-rename:hover:not(:disabled) {
  background: var(--surface-hover);
  color: var(--text);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
}

[data-theme="dark"] .abm-btn-rename.executing {
  background: rgba(91, 141, 239, 0.12);
  color: var(--accent);
  border-color: rgba(91, 141, 239, 0.25);
}

[data-theme="dark"] .abm-btn-pack {
  background: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
  border-color: rgba(76, 175, 80, 0.18);
}

[data-theme="dark"] .abm-btn-pack:hover:not(:disabled) {
  background: rgba(76, 175, 80, 0.16);
  color: #66BB6A;
  box-shadow: 0 2px 12px rgba(76, 175, 80, 0.18);
  border-color: rgba(76, 175, 80, 0.3);
}

[data-theme="dark"] .abm-btn-pack.executing {
  background: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
  border-color: rgba(76, 175, 80, 0.22);
}

[data-theme="dark"] .abm-btn-pack-main {
  background: var(--surface);
  color: var(--text-2);
  border-color: transparent;
}

[data-theme="dark"] .abm-btn-pack-main:hover:not(:disabled) {
  background: var(--surface-hover);
  color: var(--text);
  border-color: transparent;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
}

[data-theme="dark"] .abm-btn-pack-main.executing {
  background: rgba(91, 141, 239, 0.12);
  color: var(--accent);
  border-color: rgba(91, 141, 239, 0.25);
}

[data-theme="dark"] .abm-btn-pack-split {
  background: var(--surface);
  color: var(--text-2);
  border-color: transparent;
}

[data-theme="dark"] .abm-btn-pack-split:hover:not(:disabled) {
  background: var(--surface-hover);
  color: var(--text);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
}

[data-theme="dark"] .abm-btn-pack-split.executing {
  background: rgba(91, 141, 239, 0.12);
  color: var(--accent);
  border-color: rgba(91, 141, 239, 0.25);
}

[data-theme="dark"] .abm-btn-pack-split::before {
  background: linear-gradient(to bottom, transparent, var(--border), transparent);
}

[data-theme="dark"] .abm-badge {
  border-color: var(--bg);
}

[data-theme="dark"] .btn-badge {
  border-color: var(--bg);
}

[data-theme="dark"] .abm-btn-pack-main .abm-progress-bar {
  background: rgba(91, 141, 239, 0.12);
}

[data-theme="dark"] .abm-btn-rename .abm-progress-bar {
  background: rgba(91, 141, 239, 0.12);
}

[data-theme="dark"] .abm-dropdown {
  background: var(--sidebar-bg);
  border-color: var(--border);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
}

[data-theme="dark"] .abm-dropdown-item::after {
  background: var(--sidebar-bg);
  border-color: var(--border);
}
