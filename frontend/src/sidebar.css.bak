/* ================================================================
   sidebar.css — Sidebar, File Cards, Stats, Dropzone
   ================================================================ */

/* ══════════════════════════════════════
   SIDEBAR
   ══════════════════════════════════════ */
.sidebar {
  width: 295px;
  min-width: 295px;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--sidebar-bg);
  color: var(--text);
  border-right: 1px solid var(--border-light);
  animation: slideInLeft 0.35s var(--ease) both;
  user-select: none;
  position: relative;
  z-index: 20;
  box-shadow: 2px 0 12px rgba(0, 0, 0, 0.02);
}

/* -- Sidebar header -- */
.sb-header {
  padding: 22px 22px 0;
  flex-shrink: 0;
  /* 自定义拖拽区域：通过 JS 实现窗口拖动，避免 -webkit-app-region 阻止点击事件 */
  cursor: default;
}

.sb-brand {
  display: flex;
  align-items: center;
  gap: 11px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border-light);
  margin-bottom: 18px;
  /* 品牌区域可点击，不可拖拽 */
  -webkit-app-region: no-drag;
}

.sb-brand-logo {
  width: 38px;
  height: 38px;
  background: linear-gradient(135deg, var(--accent) 0%, #2563eb 100%);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 3px 10px rgba(59, 108, 245, 0.3);
  flex-shrink: 0;
}

.sb-brand-logo img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.sb-brand-info {
  flex: 1;
}

.sb-brand-text {
  font-size: 16.5px;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.03em;
  line-height: 1.2;
}

.sb-brand-sub {
  font-size: 11px;
  color: var(--text-3);
  letter-spacing: 0.01em;
  margin-top: 2px;
}

.sb-brand-badge {
  font-size: 10px;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, var(--accent) 0%, var(--purple) 100%);
  padding: 3px 9px;
  border-radius: 6px;
  letter-spacing: 0.08em;
  box-shadow: 0 2px 6px rgba(59, 108, 245, 0.25);
}

/* -- Sidebar action buttons -- */
.sb-actions {
  display: flex;
  gap: 8px;
  margin-bottom: 20px;
  /* 按钮区域不可拖拽 */
  -webkit-app-region: no-drag;
}

.sb-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 11px 14px;
  border: none;
  border-radius: var(--r-lg);
  font-size: 13.5px;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  transition: all var(--t-normal) var(--ease);
  white-space: nowrap;
  letter-spacing: 0.02em;
}

.sb-btn svg {
  width: 15px;
  height: 15px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.sb-btn-primary {
  flex: 1;
  background: var(--accent);
  color: #fff;
  box-shadow: 0 2px 10px rgba(59, 108, 245, 0.25);
}

.sb-btn-primary:hover {
  background: var(--accent-hover);
  box-shadow: 0 4px 16px rgba(59, 108, 245, 0.35);
  transform: translateY(-1px);
}

.sb-btn-ghost {
  width: 38px;
  height: 38px;
  padding: 0;
  background: transparent;
  color: var(--text-2);
  border: 1px solid var(--border-light);
}

.sb-btn-ghost:hover {
  background: var(--surface-hover);
  color: var(--text);
  border-color: var(--border);
}

/* -- 分裂按钮（添加文件/添加文件夹） -- */
.sb-btn-split {
  position: relative;
  display: flex;
  align-items: stretch;
  flex: 1;
}

.sb-btn-split-main {
  flex: 1;
  border-radius: var(--r-lg) 0 0 var(--r-lg) !important;
  border-right: none !important;
}

.sb-btn-split-arrow {
  width: 32px;
  min-width: 32px;
  height: auto;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 0 var(--r-lg) var(--r-lg) 0;
  background: var(--accent);
  color: #fff;
  border: none;
  border-left: none;
}

.sb-btn-split-arrow::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  height: 60%;
  width: 1px;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.4), transparent);
}

.sb-btn-split-arrow:hover {
  background: var(--accent-hover);
  box-shadow: 0 4px 16px rgba(59, 108, 245, 0.35);
}

.sb-btn-split-arrow svg {
  width: 14px;
  height: 14px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* -- 添加下拉菜单 -- */
.sb-dropdown {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  min-width: 150px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  padding: 4px;
  z-index: 100;
  transform-origin: top right;
  animation: sbDropdownIn 0.15s ease;
}

@keyframes sbDropdownIn {
  from {
    opacity: 0;
    transform: scale(0.95) translateY(-4px);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.sb-dropdown-item {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 10px 12px;
  border: none;
  border-radius: 8px;
  background: transparent;
  color: var(--text-2);
  font-size: 13px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  transition: all var(--t-fast) var(--ease);
  text-align: left;
}

.sb-dropdown-item:hover {
  background: var(--surface-hover);
  color: var(--text);
}

.sb-dropdown-item svg {
  width: 16px;
  height: 16px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
  flex-shrink: 0;
}

/* -- Sort Dropdown -- */
.sort-dropdown-container {
  position: relative;
}

.sort-dropdown {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  min-width: 160px;
  background: var(--white);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-lg);
  border: 1px solid var(--border-light);
  overflow: hidden;
  z-index: 100;
  animation: fadeIn 0.15s ease;
  opacity: 1;
  transform: translateY(0);
}

.sort-dropdown.closing {
  animation: fadeOut 0.15s ease forwards;
}

@keyframes fadeOut {
  from { opacity: 1; transform: translateY(0); }
  to   { opacity: 0; transform: translateY(-8px); }
}

.sort-dropdown-header {
  padding: 8px 12px;
  font-size: 11px;
  color: var(--text-3);
  border-bottom: 1px solid var(--border-light);
  background: var(--surface);
}

.sort-dropdown-item {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 10px 12px;
  text-align: left;
  font-size: 13px;
  color: var(--text-2);
  background: transparent;
  border: none;
  cursor: pointer;
  transition: background var(--t-fast);
}

.sort-dropdown-item:hover {
  background: var(--surface-hover);
  color: var(--text);
}

.sort-dropdown-item.active {
  background: var(--accent-soft);
  color: var(--accent);
}

.sort-dropdown-item svg {
  width: 14px;
  height: 14px;
  flex-shrink: 0;
}

/* -- Sidebar section header -- */
.sb-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  margin-bottom: 8px;
}

.sb-section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px 10px;
}

.sb-section-title span {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-3);
  letter-spacing: 0.06em;
}

.sb-section-title .count {
  font-family: 'MiSans', 'NotoSansSymbols', 'NotoSansSymbols2', 'PingFang SC', 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 11px;
  font-weight: 500;
  color: var(--text-3);
  background: var(--surface);
  padding: 2px 8px;
  border-radius: 6px;
}

.sb-search-bar {
  flex: 1;
  height: 32px;
  background-color: var(--surface);
  border-radius: var(--r-lg);
  display: flex;
  align-items: center;
  padding: 0 12px;
  margin-right: 12px;
  transition: background-color 0.2s ease;
}

.sb-search-bar:hover {
  background-color: var(--surface-hover);
}

.sb-search-icon {
  width: 16px;
  height: 16px;
  margin-right: 8px;
  color: var(--text-3);
  flex-shrink: 0;
}

.sb-search-input {
  flex: 1;
  height: 100%;
  border: none;
  outline: none;
  font-size: 13px;
  color: var(--text);
  background: transparent;
  font-family: inherit;
}

.sb-search-input::placeholder {
  color: var(--text-3);
}

/* -- Search clear button -- */
.sb-search-clear {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  padding: 0;
  border: none;
  border-radius: 50%;
  background: var(--text-3);
  color: white;
  cursor: pointer;
  transition: all 0.15s ease;
  flex-shrink: 0;
  margin-left: 4px;
}

.sb-search-clear:hover {
  background: var(--text-2);
  transform: scale(1.1);
}

.sb-search-clear svg {
  width: 12px;
  height: 12px;
}

/* -- Search empty state -- */
.sb-search-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  text-align: center;
}

.sb-search-empty-icon {
  width: 228px;
  height: 228px;
  margin-bottom: -28px;
  color: var(--text-3);
}

.sb-search-empty-icon img {
  width: 100%;
  height: 100%;
}

.sb-search-empty-text {
  font-size: 14px;
  color: var(--text-2);
  margin-bottom: 10px;
}

.sb-search-empty-clear {
  padding: 6px 16px;
  background: var(--accent-soft);
  color: var(--accent);
  border: 1px solid var(--accent);
  border-radius: var(--r-md);
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.sb-search-empty-clear:hover {
  background: var(--accent);
  color: white;
}

/* -- Sidebar file list -- */
.sb-files {
  flex: 1;
  min-height: 0;
  padding: 0 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}

.sb-files::-webkit-scrollbar { width: 4px; }
.sb-files::-webkit-scrollbar-track { background: transparent; }
.sb-files::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 2px;
}
.sb-files::-webkit-scrollbar-thumb:hover {
  background: var(--text-4);
}

/* -- Virtual scroll container -- */
.sb-files-scrollable {
  flex: 1;
  min-height: 200px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
  will-change: scroll-position;
  contain: layout style paint;
}

.sb-files-scrollable::-webkit-scrollbar { width: 4px; }
.sb-files-scrollable::-webkit-scrollbar-track { background: transparent; }
.sb-files-scrollable::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 2px;
}
.sb-files-scrollable::-webkit-scrollbar-thumb:hover {
  background: var(--text-4);
}

/* -- File card -- */
.file-card {
  padding: 13px 14px;
  border-radius: var(--r-lg);
  cursor: pointer;
  transition: all var(--t-fast) var(--ease);
  border: 1.5px solid transparent;
  position: relative;
  box-shadow: var(--shadow-sm);
  /* 固定行高配合 react-window 虚拟滚动，防止 layout shift */
  height: 64px;
  overflow: hidden;
}

.file-card:hover {
  background: var(--surface);
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.file-card:hover .file-card-close,
.file-card:hover .file-card-rotate {
  opacity: 1;
}

.file-card-rotate {
  position: absolute;
  top: 0; bottom: 0; right: 34px;
  margin: auto 0;
  width: 22px; height: 22px;
  border: none; border-radius: 50%;
  background: rgba(0, 0, 0, 0.08);
  color: var(--text-3);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  opacity: 0;
  transition: opacity var(--t-fast), background var(--t-fast);
  padding: 0;
}

.file-card-rotate svg { width: 14px; height: 14px; }
.file-card-rotate:hover { background: rgba(59, 108, 245, 0.15); color: var(--primary); }

.file-card-close {
  position: absolute;
  top: 0; bottom: 0; right: 8px;
  margin: auto 0;
  width: 22px; height: 22px;
  border: none; border-radius: 50%;
  background: rgba(0, 0, 0, 0.08);
  color: var(--text-3);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  opacity: 0;
  transition: opacity var(--t-fast), background var(--t-fast);
  padding: 0;
}

.file-card-close svg { width: 14px; height: 14px; }
.file-card-close:hover { background: rgba(229, 62, 62, 0.15); color: var(--danger); }

.file-card.active {
  background: var(--accent-soft);
  border-color: rgba(59, 108, 245, 0.12);
  box-shadow: 0 1px 4px rgba(59, 108, 245, 0.06);
  overflow: hidden;
}

.file-card.active::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: var(--accent);
  border-radius: 0 3px 3px 0;
}

.file-card.active .fc-amount { color: var(--accent); }

.fc-row-top {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.fc-type {
  font-size: 10px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 5px;
  white-space: nowrap;
  letter-spacing: 0.02em;
  flex-shrink: 0;
}

.fc-type.zp { background: var(--red-soft); color: var(--red); }
.fc-type.pp { background: var(--accent-soft); color: var(--accent); }
.fc-type.elec { background: var(--green-soft); color: var(--green); }

.fc-name {
  font-size: 12.5px;
  font-weight: 400;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  letter-spacing: -0.01em;
  padding-right: 14px;
}

.fc-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  flex-shrink: 0;
}

.fc-dot.ready { background: var(--green); box-shadow: 0 0 0 3px var(--green-soft); }
.fc-dot.pending { background: var(--orange); box-shadow: 0 0 0 3px var(--orange-soft); }
.fc-dot.failed { background: var(--red); box-shadow: 0 0 0 3px var(--red-soft); }
.fc-dot.duplicate { background: var(--orange); box-shadow: 0 0 0 3px var(--orange-soft); }

.fc-row-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.fc-invoice-no {
  font-family: 'MiSans', 'NotoSansSymbols', 'NotoSansSymbols2', 'PingFang SC', 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 10.5px;
  color: var(--text-3);
  letter-spacing: 0.02em;
}

.fc-amount {
  font-family: 'MiSans', 'NotoSansSymbols', 'NotoSansSymbols2', 'PingFang SC', 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 12.5px;
  font-weight: 500;
  color: var(--text);
}

.fc-failed { color: #ef4444 !important; font-size: 11px; opacity: 0.85; }

/* -- Sidebar stats -- */
.sb-stats {
  flex-shrink: 0;
  margin: auto 22px 18px;
  background: var(--surface);
  border-radius: var(--r-xl);
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.sb-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12px 0;
}

.sb-stat + .sb-stat {
  border-left: 1px solid var(--border-light);
}

.sb-stat-icon {
  width: 32px; height: 32px;
  border-radius: var(--r-md);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 8px;
}

.sb-stat-icon svg { width: 16px; height: 16px; }
.sb-stat-icon.blue { background: var(--accent-soft); color: var(--accent); }
.sb-stat-icon.blue svg { fill: var(--accent); stroke: none; }
.sb-stat-icon.green { background: var(--green-soft); color: var(--green); }
.sb-stat-icon.green svg { fill: var(--green); stroke: none; }
.sb-stat-icon.purple { background: var(--purple-soft); color: var(--purple); }
.sb-stat-icon.purple svg { fill: var(--purple); stroke: none; }
.sb-stat-icon.red { background: var(--danger-bg); color: var(--danger); }
.sb-stat-icon.red svg { fill: var(--danger); stroke: none; }
.sb-stat-icon.orange { background: rgba(245, 158, 11, 0.1); color: var(--orange); }
.sb-stat-icon.orange svg { fill: var(--orange); stroke: none; }

.sb-stat-val {
  font-family: 'MiSans', 'NotoSansSymbols', 'NotoSansSymbols2', 'PingFang SC', 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 16px;
  font-weight: 500;
  color: var(--text);
  display: block;
  line-height: 1.2;
  animation: countPop 0.4s var(--ease) both;
}

.sb-stat-val.brand { color: var(--accent); }
.sb-stat-val.error { color: var(--danger); font-weight: 600; }
.sb-stat-val.orange { color: var(--orange); font-weight: 600; }

.sb-stat-label {
  font-size: 10.5px;
  color: var(--text-3);
  margin-top: 3px;
}

/* -- 失败文件数量显示 -- */
.sb-stat-btn-remove-failed {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  border: none;
  border-radius: var(--r-md);
  background: var(--danger-bg);
  color: var(--danger);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--t-fast) var(--ease);
  font-family: inherit;
}

.sb-stat-btn-remove-failed:hover {
  background: rgba(229, 62, 62, 0.15);
  transform: translateY(-1px);
}

.sb-stat-btn-remove-failed svg {
  width: 14px; height: 14px;
  stroke: var(--danger); stroke-width: 2;
  stroke-linecap: round; stroke-linejoin: round;
}

/* -- 侧边栏移除失败文件区域 -- */
.sb-stat.sb-stat-remove-failed {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 8px 0;
}

.sb-stat-failed-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px; height: 32px;
  border: none;
  border-radius: var(--r-md);
  background: var(--danger-bg);
  color: var(--danger);
  cursor: pointer;
  transition: all var(--t-fast) var(--ease);
}

.sb-stat-failed-btn:hover {
  background: rgba(229, 62, 62, 0.15);
  transform: translateY(-1px);
}

.sb-stat-failed-btn svg {
  width: 14px; height: 14px;
  stroke: var(--danger); stroke-width: 2;
  stroke-linecap: round; stroke-linejoin: round;
}

.sb-stat-failed-label {
  font-size: 11px;
  color: var(--danger);
  font-weight: 500;
}

/* -- 侧边栏移除重复文件区域 -- */
.sb-stat.sb-stat-remove-duplicate {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 8px 0;
}

.sb-stat-duplicate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px; height: 32px;
  border: none;
  border-radius: var(--r-md);
  background: rgba(245, 158, 11, 0.1);
  color: var(--orange);
  cursor: pointer;
  transition: all var(--t-fast) var(--ease);
}

.sb-stat-duplicate-btn:hover {
  background: rgba(245, 158, 11, 0.15);
  transform: translateY(-1px);
}

.sb-stat-duplicate-btn svg {
  width: 14px; height: 14px;
  stroke: var(--orange); stroke-width: 2;
  stroke-linecap: round; stroke-linejoin: round;
}

.sb-stat-duplicate-count {
  font-family: 'MiSans', 'NotoSansSymbols', 'NotoSansSymbols2', 'PingFang SC', 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: var(--orange);
  display: block;
  line-height: 1.2;
}

.sb-stat-duplicate-label {
  font-size: 11px;
  color: var(--orange);
  font-weight: 500;
}

/* -- Dropzone area -- */
.dropzone-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 22px 22px;
  padding: 36px 24px;
  border: 2px dashed var(--border-light);
  border-radius: var(--r-xl);
  cursor: pointer;
  transition: all var(--t-normal) var(--ease);
  text-align: center;
  min-height: 0;
}

.dropzone-area:hover {
  border-color: var(--accent);
  background: var(--accent-soft);
}

.dropzone-area.drag-active {
  border-color: var(--accent);
  background: var(--accent-soft);
  border-style: solid;
}

.dropzone-icon {
  margin-bottom: 16px;
  opacity: 0.7;
  color: var(--accent);
  transition: opacity var(--t-fast), transform var(--t-fast);
}

.dropzone-area:hover .dropzone-icon {
  opacity: 1;
  transform: scale(1.05);
}

.dropzone-text {
  color: var(--text-2);
  font-size: 13px;
  margin-bottom: 6px;
  font-weight: 500;
}

.dropzone-formats {
  color: var(--text-4);
  font-size: 11px;
  text-align: center;
  margin-bottom: 16px;
  letter-spacing: 0.02em;
}

.dropzone-text-active {
  color: var(--accent);
  font-size: 13px;
  font-weight: 600;
}

.dropzone-btn {
  padding: 8px 20px;
  background: var(--accent);
  color: #fff;
  border: none;
  border-radius: var(--r-md);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: inherit;
  transition: all var(--t-fast) var(--ease);
  box-shadow: 0 2px 8px rgba(59, 108, 245, 0.25);
}

.dropzone-btn:hover {
  background: var(--accent-hover);
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(59, 108, 245, 0.35);
}

/* ======================== Merge & Duplicate Groups ======================== */
.merge-group-first {
  overflow: hidden;
  border-bottom: none;
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
}

.merge-group-last {
  border-top: 1px dashed var(--border-light);
  border-top-left-radius: 0;
  border-top-right-radius: 0;
  margin-top: -1px;
}

.merge-group-label {
  position: absolute;
  top: -1px; right: 8px;
  font-size: 9px;
  background: var(--accent);
  color: #fff;
  padding: 1px 6px;
  border-radius: 0 0 4px 4px;
  font-weight: 600;
  letter-spacing: 0.3px;
  z-index: 1;
}

.merge-tag { background: #f59e0b; color: #fff; }

.merge-group-first::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: var(--accent);
  border-radius: 3px 0 0 3px;
}
.file-card.has-failed { overflow: hidden; }

.file-card.has-failed::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: #dc2626;
  opacity: 0.75;
  border-radius: 3px 0 0 3px;
}

/* -- 重复发票标记 -- */
.file-card.duplicate { position: relative; overflow: hidden; }

.duplicate-bar {
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: #f59e0b;
  border-radius: 3px 0 0 3px;
  z-index: 2;
}

.duplicate-label {
  position: absolute;
  top: -1px; right: 28px;
  font-size: 9px;
  background: #f59e0b;
  color: #fff;
  padding: 1px 6px;
  border-radius: 0 0 4px 4px;
  font-weight: 600;
  letter-spacing: 0.3px;
  z-index: 1;
}

.merge-group-first ~ .duplicate-label,
.file-card:has(.merge-group-label) .duplicate-label {
  right: 80px;
}

/* -- 解析中进度条 -- */
.file-card.parsing { overflow: hidden; }

.fc-progress-bar {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
  background: rgba(59, 108, 245, 0.15);
  overflow: hidden;
}

.fc-progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 0 2px 2px 0;
  animation: progressSlide 1.5s ease-in-out infinite;
}

@keyframes progressSlide {
  0%   { width: 5%; opacity: 0.6; }
  50%  { width: 85%; opacity: 1; }
  100% { width: 95%; opacity: 0.4; }
}

/* ======================== Import Progress Modal ======================== */
.import-modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 20, 30, 0.45);
  backdrop-filter: blur(3px);
  animation: importOverlayIn 0.2s ease-out both;
}

.import-modal-overlay.import-modal-out {
  animation: importOverlayOut 0.25s ease-in both;
  pointer-events: none;
}

@keyframes importOverlayIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes importOverlayOut {
  from { opacity: 1; }
  to   { opacity: 0; }
}

.import-modal-box {
  background: var(--sidebar-bg);
  border: 1px solid var(--border-light);
  border-radius: 12px;
  padding: 28px 36px 24px;
  min-width: 220px;
  max-width: 300px;
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  animation: importBoxIn 0.22s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

.import-modal-box.import-modal-box-out {
  animation: importBoxOut 0.2s ease-in both;
}

@keyframes importBoxIn {
  from { opacity: 0; transform: scale(0.88) translateY(8px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes importBoxOut {
  from { opacity: 1; transform: scale(1); }
  to   { opacity: 0; transform: scale(0.92); }
}

.import-modal-icon {
  color: var(--brand);
  animation: spin 1.1s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.import-modal-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--text);
  margin: 0;
  text-align: center;
  line-height: 1.4;
}

.import-modal-track {
  width: 100%;
  height: 4px;
  background: var(--border-light);
  border-radius: 4px;
  overflow: hidden;
}

.import-modal-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--brand) 0%, #60a5fa 100%);
  border-radius: 4px;
  transition: width 0.3s ease-out;
}

.import-modal-pct {
  font-size: 12px;
  color: var(--text-3);
  align-self: flex-end;
}

/* ================================================================
   DARK MODE — sidebar
   ================================================================ */
[data-theme="dark"] .file-card-close,
[data-theme="dark"] .file-card-rotate {
  background: var(--surface-hover);
  color: var(--text-3);
}

[data-theme="dark"] .file-card-close:hover {
  background: rgba(239, 83, 80, 0.18);
  color: var(--danger);
}

[data-theme="dark"] .file-card-rotate:hover {
  background: var(--accent-soft);
  color: var(--accent);
}

[data-theme="dark"] .file-card:hover {
  background: var(--surface);
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

[data-theme="dark"] .file-card:hover::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255, 255, 255, 0.03);
  border-radius: inherit;
  pointer-events: none;
}

[data-theme="dark"] .file-card.active {
  background: var(--accent-soft);
  border-color: var(--accent-medium);
  box-shadow: 0 1px 4px rgba(91, 141, 239, 0.08);
  overflow: hidden;
}

[data-theme="dark"] .file-card.active::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: var(--accent);
  border-radius: 0 3px 3px 0;
}

[data-theme="dark"] .sb-search-clear {
  background: var(--text-3);
  color: var(--bg);
}

[data-theme="dark"] .sb-search-clear:hover {
  background: var(--text-2);
}

[data-theme="dark"] .sb-search-empty-clear:hover {
  background: var(--accent);
  color: #fff;
}

[data-theme="dark"] .dropzone-area {
  border-color: var(--border-light);
}

[data-theme="dark"] .dropzone-area:hover {
  border-color: var(--accent);
  background: var(--accent-soft);
}

[data-theme="dark"] .dropzone-area.drag-active {
  background: var(--accent-soft);
  border-color: var(--accent);
}

[data-theme="dark"] .merge-group-last {
  border-top-color: var(--border);
}

[data-theme="dark"] .import-modal-box {
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.55);
}

[data-theme="dark"] .import-modal-fill {
  background: linear-gradient(90deg, var(--accent) 0%, #6E9EF2 100%);
}

[data-theme="dark"] .fc-failed {
  color: var(--danger) !important;
}

[data-theme="dark"] .sb-stat + .sb-stat {
  border-left-color: var(--border);
}

/* -- dark: 分裂按钮 -- */
[data-theme="dark"] .sb-btn-split-arrow {
  background: var(--accent);
  color: #fff;
}

[data-theme="dark"] .sb-btn-split-arrow:hover {
  background: var(--accent-hover);
}

[data-theme="dark"] .sb-dropdown {
  background: var(--sidebar-bg);
  border-color: var(--border);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
}

[data-theme="dark"] .sb-dropdown-item:hover {
  background: var(--surface-hover);
}
