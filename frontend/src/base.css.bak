/* ================================================================
   base.css — Reset, Scrollbar, Animations, Focus, Responsive
   ================================================================ */

/* ======================== Global Reset ======================== */
* {
  font-family: 'MiSans', 'NotoSansSymbols', 'NotoSansSymbols2', 'PingFang SC', 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;
  box-sizing: border-box;
}

input:focus,
select:focus,
textarea:focus,
button:focus {
  outline: none;
}

html {
  scroll-behavior: smooth;
}

.mono {
  font-family: 'MiSans', 'NotoSansSymbols', 'NotoSansSymbols2', 'PingFang SC', 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;
}

/* ======================== Scrollbar ======================== */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-4); }

[data-theme="dark"] ::-webkit-scrollbar-thumb {
  background: var(--border);
}

[data-theme="dark"] ::-webkit-scrollbar-thumb:hover {
  background: var(--text-4);
}

* {
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}

/* ======================== Animations ======================== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes previewFadeIn {
  from { opacity: 0; transform: scale(0.98); }
  to   { opacity: 1; transform: scale(1); }
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 2px rgba(59, 108, 245, 0.25), inset 0 0 20px rgba(59, 108, 245, 0.03); }
  50%      { box-shadow: 0 0 0 4px rgba(59, 108, 245, 0.4), inset 0 0 30px rgba(59, 108, 245, 0.06); }
}

@keyframes progressPulse {
  0%, 100% { opacity: 1; }
  50%      { opacity: 0.5; }
}

@keyframes successPop {
  0%  { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

@keyframes slideInLeft {
  from { opacity: 0; transform: translateX(-12px); }
  to   { opacity: 1; transform: translateX(0); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes modalScaleIn {
  from { opacity: 0; transform: scale(0.92); }
  to   { opacity: 1; transform: scale(1); }
}

@keyframes modalScaleOut {
  from { opacity: 1; transform: scale(1); }
  to   { opacity: 0; transform: scale(0.95); }
}

@keyframes paperIn {
  from { opacity: 0; transform: translateY(16px) scale(0.99); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes selectPulse {
  0%   { box-shadow: 0 0 0 0 rgba(59, 108, 245, 0.25); }
  70%  { box-shadow: 0 0 0 6px rgba(59, 108, 245, 0); }
  100% { box-shadow: 0 0 0 0 rgba(59, 108, 245, 0); }
}

@keyframes progressFade {
  0%   { opacity: 0; transform: translateX(10px); }
  15%  { opacity: 1; transform: translateX(0); }
  85%  { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes countPop {
  0%   { opacity: 0; transform: translateY(6px) scale(0.95); }
  60%  { opacity: 1; transform: translateY(-1px) scale(1.02); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

.drag-active { animation: pulse 1.2s ease-in-out infinite; }
.file-item-enter { animation: fadeIn 0.3s var(--ease) forwards; }
.preview-fade-in { animation: previewFadeIn 0.3s var(--ease) forwards; }
.progress-loading { animation: progressPulse 1.5s ease-in-out infinite; }
.success-pop { animation: successPop 0.3s ease-out; }

/* ======================== Button Click ======================== */
button:active:not(:disabled) {
  transform: scale(0.97);
  transition: transform 0.1s;
}

/* ======================== Focus & Responsive ======================== */
@media (max-width: 1100px) {
  .sidebar {
    width: 260px;
    min-width: 260px;
  }
}
